
# Monorepo-wide .gitignore

# OS and editor files
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs and debug output
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Node / Next.js
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.next/
out/
build/
dist/
dist-ssr/
coverage/
.vercel/
*.tsbuildinfo
next-env.d.ts

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Environment and secrets
.env
.env.*
*.local
*.pem
secrets/

# Repo-generated runtime data
chroma_db/
tmp_repos/
